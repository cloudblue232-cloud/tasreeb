{
  "name": "saudi-leaks-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:main": "npm run dev --workspace @saudi-leaks/main",
    "dev:admin": "npm run dev --workspace @saudi-leaks/admin",
    "build:main": "npm run build --workspace @saudi-leaks/main",
    "build:admin": "npm run build --workspace @saudi-leaks/admin",
    "start:main": "npm run start --workspace @saudi-leaks/main",
    "start:admin": "npm run start --workspace @saudi-leaks/admin",
    "lint:main": "npm run lint --workspace @saudi-leaks/main",
    "lint:admin": "npm run lint --workspace @saudi-leaks/admin"
  },
  "dependencies": {},
  "devDependencies": {}
}
